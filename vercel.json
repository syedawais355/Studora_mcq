{
  "version": 2,
  "functions": {
    "api/category-pdf.js": {
      "includeFiles": "lib/fonts/**",
      "maxDuration": 60
    },
    "api/exam-pdf.js": {
      "includeFiles": "lib/fonts/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/subjects/:slug*", "destination": "/" },
    { "source": "/exams/:slug*",    "destination": "/" },
    { "source": "/q/:id",           "destination": "/" },
    { "source": "/about",           "destination": "/" },
    { "source": "/bookmarks",       "destination": "/" },
    { "source": "/quiz",            "destination": "/" },
    { "source": "/home",            "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://lh3.googleusercontent.com; connect-src 'self' https://xwvvxhkfndchpbyyaych.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com; object-src 'none'" }
      ]
    },
    {
      "source": "/assets/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=86400, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
